# dependencies
# Removing the leading slash allows Git to find node_modules in /client and /server
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js / frontend builds
.next/
out/
build/
dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files 
# This will now catch /client/.env and /server/.env
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts